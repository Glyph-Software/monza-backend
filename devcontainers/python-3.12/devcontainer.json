{
    "name": "Python 3.12 Sandbox",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
      "ghcr.io/devcontainers/features/git:1": {}
    },
    "postCreateCommand": "python -v",
    "forwardPorts": [3000],
    "customizations": {
      "vscode": {
        "extensions": ["ms-python.python"]
      }
    }
  }
  
  